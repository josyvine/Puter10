<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 
        In the Puter Unofficial app, the Home Fragment serves as the 
        primary container for the AI Chat interface if you are using 
        the Navigation Component from your template.
        
        It contains the WebView which loads the index.html.
    -->

    <android.webkit.WebView
        android:id="@+id/homeWebView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 
        A small overlay indicator can be added here if needed, 
        but per your instruction, the HTML handles the full UI.
    -->

</androidx.constraintlayout.widget.ConstraintLayout>